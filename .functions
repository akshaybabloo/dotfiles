#!/bin/bash

function _whereami() {
    if [[ $0 == -* ]]; then
        if [[ $SHELL == */zsh ]]; then
            script_dir=$(dirname "$ZSH_ARGZERO")
        elif [[ $SHELL == */bash ]]; then
            script_dir=$(dirname "${BASH_SOURCE[0]}")
        else
            echo "Unsupported shell: $SHELL"
            exit 1
        fi
    else
        script_dir=$(dirname "${BASH_SOURCE[0]}")
    fi

    echo $script_dir
}

function _loading() {
    local pid=$1
    local message=${2:-"Processing"}
    local sp="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
    local i=0
    local start_time=$(date +%s)
    
    # Color codes
    local GREEN='\033[0;32m'
    local RED='\033[0;31m'
    local NC='\033[0m'
    
    # Trap to ensure cursor is restored
    trap 'tput cnorm 2>/dev/null; trap - RETURN INT TERM' RETURN INT TERM
    
    # Hide cursor
    tput civis 2>/dev/null
    
    # Validate PID
    if ! [[ "$pid" =~ ^[0-9]+$ ]]; then
        echoerr "Invalid process ID: $pid"
        tput cnorm 2>/dev/null
        return 1
    fi
    
    # Check if process exists
    if ! kill -0 "$pid" 2>/dev/null; then
        echoerr "Process $pid does not exist"
        tput cnorm 2>/dev/null
        return 1
    fi
    
    # Show message and spinner
    printf "%s " "$message"
    
    # Spin until process completes
    while kill -0 "$pid" 2>/dev/null; do
        printf "\b%s" "${sp:$i:1}"
        i=$(( (i + 1) % ${#sp} ))
        sleep 0.1
    done
    
    # Calculate elapsed time
    local end_time=$(date +%s)
    local elapsed=$((end_time - start_time))
    
    # Wait for the process and get its exit status
    wait "$pid" 2>/dev/null
    local exit_status=$?
    
    # Clear spinner and show result with time
    if [[ $exit_status -eq 0 ]]; then
        printf "\b${GREEN}✓${NC} (${elapsed}s)\n"
    else
        printf "\b${RED}✗${NC} (${elapsed}s)\n"
    fi
    
    # Restore cursor
    tput cnorm 2>/dev/null
    
    return $exit_status
}

function _requireSuperuser() {
    local file=$1
    local operation=${2:-write}  # Default to write operation

    # Check if file/directory exists
    if [[ ! -e "$file" ]]; then
        # For non-existent files, check parent directory
        local parent_dir=$(dirname "$file")
        if [[ ! -w "$parent_dir" ]]; then
            return 1  # Need sudo to create file in this directory
        fi
        return 0
    fi

    # Check based on operation type
    case "$operation" in
        read)
            if [[ -r "$file" ]]; then
                return 0  # Can read, no sudo needed
            fi
            ;;
        write|edit|delete)
            if [[ -w "$file" ]]; then
                return 0  # Can write, no sudo needed
            fi
            ;;
        *)
            echoerr "Error: Unknown operation '$operation'"
            return 2
            ;;
    esac

    # If we reach here, we don't have the required permission
    return 1  # Need sudo
}

function _redText() { printf "\e[1m\e[31m%s\e[0m\n" "$1"; }
function _greenText() { printf "\e[1m\e[32m%s\e[0m\n" "$1"; }
function _blueText() { printf "\e[1m\e[94m%s\e[0m\n" "$1"; }

function _wslHomePath() {
    # Check if in WSL
    if ! grep -qEi "(Microsoft|WSL)" /proc/version &> /dev/null; then
        die "Error: This function is intended to be used in WSL (Windows Subsystem for Linux)."
    fi

    # Get Windows username and construct the home path
    local win_user=$(powershell.exe -Command "[System.Environment]::UserName" 2>/dev/null | tr -d '\r')
    local path=$(wslpath "C:\\Users\\$win_user")
    echo "$path"
}

## h2: General Functions

## `sudo_if_needed` checks if the file requires superuser permissions and returns `sudo` if needed
## Usage: `sudo_if_needed <file>`
function sudo_if_needed() {
    local file=$1
    local operation=${2:-write}

    if _requireSuperuser "$file" "$operation"; then
        echo ""
    else
        echo "sudo"
    fi
}

## `die` echoes the first argument as an error message and exits the shell
## Usage: `die "Error: Something went wrong."`
function die() { echoerr $@ ; exit 1; }

## Create a new directory and enter it
## Usage: `mkd <dirname>`
function mkd() {
	mkdir -p "$@" && cd "$_"
}

## Create a .tar.gz archive, using `zopfli`, `pigz` or `gzip` for compression
## Usage: `Usage: targz [--name custom_name] <path to file or directory>...`
function targz() {
    local outputName="compressed_files"
    local files=()

    # Parse arguments
    for arg in "$@"; do
        case "$arg" in
            --name)
                outputNameSet=true
                ;;
            *)
                if [[ "$outputNameSet" == true ]]; then
                    outputName="$arg"
                    outputNameSet=false
                else
                    files+=("$arg")
                fi
                ;;
        esac
    done

    # Check if any files were provided
    if [ ${#files[@]} -eq 0 ]; then
        echo "Usage: targz [--name custom_name] <path to file or directory>..."
        return 1
    fi

    # Check for existing compressed file and increment name if exists
    local tmpFile="${outputName}.tar"
    local counter=0
    while [ -f "${tmpFile}.gz" ]; do
        let counter++
        tmpFile="${outputName}${counter}.tar"
    done

    # Create tar file
    tar -cvf "${tmpFile}" --exclude=".DS_Store" "${files[@]}" || return 1

    # Determine compression command
    local cmd=""
    local size=$(stat -c"%s" "${tmpFile}" 2>/dev/null || stat -f"%z" "${tmpFile}" 2>/dev/null)
    if ((size < 52428800)) && command -v zopfli >/dev/null; then
        cmd="zopfli"
    else
        if command -v pigz >/dev/null; then
            cmd="pigz"
        else
            cmd="gzip"
        fi
    fi

    echo "Compressing .tar ($((size / 1000)) kB) using \`${cmd}\`…"
    "${cmd}" -v "${tmpFile}" || return 1
    [ -f "${tmpFile}" ] && rm "${tmpFile}"

    local zippedSize=$(stat -c"%s" "${tmpFile}.gz" 2>/dev/null || stat -f"%z" "${tmpFile}.gz" 2>/dev/null)
    echo "${tmpFile}.gz ($((zippedSize / 1000)) kB) created successfully."
}

## ::: danger Requirements
## This function requires Python 3.10 or higher.
## :::
## ::: info Optional Requirements
## You can also use Caddy serve, install it from https://caddyserver.com/docs/install
## :::
## > If a caddy server is installed then that is preferred over Python.
##
## Start an HTTP server from a directory, optionally specifying the port
## Usage: `server [path] [port]`
function server() {
    local path="${1:-.}"
    local port="${2:-52600}"
    
    sleep 1 && open "http://localhost:${port}/" &

    # Check if Caddy server is installed
    if command -v caddy &> /dev/null; then
        echo "Starting server at http://localhost:${port}/"
        caddy file-server --browse --listen :$port --root $path
    else
        # Set the default Content-Type to `text/plain` instead of `application/octet-stream`
        # And serve everything as UTF-8 (although not technically correct, this doesn’t break anything for binary files)
        python3 -c $'import http.server;\nclass MyHandler(http.server.SimpleHTTPRequestHandler):\n\tdef guess_type(self, path):\n\t\text = super().guess_type(path);\n\t\tif ext == "application/octet-stream":\n\t\t\text = "text/plain";\n\t\treturn ext + ";charset=UTF-8";\n\nhttp.server.test(HandlerClass=MyHandler, port=int('$port'))'
    fi
}

## Normalize `open` across Linux, macOS, and Windows.
## This is needed to make the `o` function (see below) cross-platform.
if [ ! $(uname -s) = 'Darwin' ]; then
	if grep -q Microsoft /proc/version; then
		# Ubuntu on Windows using the Linux subsystem
		alias open='explorer.exe'
	else
		alias open='xdg-open'
	fi
fi

## `o` with no arguments opens the current directory, otherwise opens the given
## location
## Usage: `o`, `o .`, `o ~/`, `o ./myproject`, etc.
function o() {
	if [ $# -eq 0 ]; then
		open .
	else
		open "$@"
	fi
}

## ::: danger Requirements
## This function requires `tree` - `sudo apt install tree`.
## :::
## `tre` is a shorthand for `tree` with hidden files and color enabled, ignoring
## the `.git` directory, listing directories first. The output gets piped into
## `less` with options to preserve color and line numbers, unless the output is
## small enough for one screen.
## Usage: `tre <directory>`
function tre() {
	# Check if tree is installed
	if ! command -v tree &>/dev/null; then
		echoerr "Error: tree is not installed. Please install it from - sudo apt install tree"
		return
	fi

	tree -aC -I '.git|node_modules|bower_components' --dirsfirst "$@" | less -FRNX
}

## ::: danger Requirements
## This function requires `git` - `sudo apt install git`.
## :::
## `ginit` initailises a git repository and makes an initial commit
## Usage: `ginit` or `ginit "Initial commit"`
function ginit() {
	# Check if git is installed
	if ! command -v git &>/dev/null; then
		echoerr "Error: git not found. Please install git from https://git-scm.com/downloads"
		return
	fi

	local commit_message="${1:-Initial commit}"
	git init && git add . && git commit -m "$commit_message"
}

## `echoerr` echoes the first argument to stderr. Useful for printing errors.
## Usage: `echoerr "Error: Something went wrong."`
function echoerr() { _redText "$*" >&2; }

## `dlc` deletes all lines that start with the specified comment symbol
## Usage: `dlc "<file>" "<comment_symbol>"`
function dlc() {
	local file=$1
	local comment_symbol=$2
	local temp_file="${file}.tmp"

	# Check if the file exists, if not display an error message and return
	if [[ ! -f $file ]]; then
		echoerr "Error: $file not found."
		return
	fi

	# Remove inline comments and full-line comments while preserving necessary newlines
	awk -v symbol="$comment_symbol" '
    {
        line = $0
        if (line ~ "^[[:space:]]*" symbol ".*$") {
            if (prev_line !~ "^[[:space:]]*" symbol ".*$") {
                print ""
            }
        } else {
            sub("[[:space:]]*" symbol ".*", "", line)
            if (length(line) > 0) {
                print line
            } else if (prev_line !~ "^[[:space:]]*" symbol ".*$") {
                print ""
            }
        }
        prev_line = $0
    }
    ' "$file" >"$temp_file"

	# Replace the original file with the temporary file
	mv "$temp_file" "$file"
}

## Converts all file names in the current directory to some UUID names leaving the extension intact
## Usage: `uuidf`
function uuidf() {
    # Loop over all files in the current directory
    for file in *; do
        # Skip if it's a directory
        if [[ -d "$file" ]]; then
            continue
        fi

        # Extract the file extension
        extension="${file##*.}"

        # Generate a GUID
        guid=$(uuidgen)

        # Rename the file, keeping the original extension
        mv "$file" "${guid}.${extension}"
    done

}

## `snapc` cleans up old snap versions
## Usage: `sudo snapc`
function snapc() {
    # Check if snap is installed
    if ! command -v snap &> /dev/null; then
        echoerr "Error: snap not found. Please install snap from https://snapcraft.io/docs/installing-snapd"
        return
    fi

    # Taken from - https://www.debugpoint.com/clean-up-snap/
    # Remove old revisions of snaps
    # CLOSE ALL SNAPS BEFORE RUNNING THIS
    set -eu

    snap list --all | awk '/disabled/{print $1, $3}' |
        while read snapname revision; do
            sudo_if_needed snap remove "$snapname" --revision="$revision"
        done
}

## `debi` installs a .deb file using `apt install`
## Usage: `debi <file.deb>`
function debi() {
    # Check if the first argument is not empty
    if [[ -z $1 ]]; then
        echoerr "Error: No arguments provided."
        return
    fi

    # Check if the first argument is a valid file
    if [[ ! -f $1 ]]; then
        echoerr "Error: $1 is not a valid file."
        return
    fi

    # Move file to /tmp
    local tmp_file="/tmp/$(basename "$1")"
    mv "$1" "$tmp_file"

    # Install the deb using sudo apt install
    sudo apt install -y "$tmp_file"
}

## `lsu` lists all USB devices connected to the system
## Usage: `lsu`
function lsu() {
    for sysdevpath in $(find /sys/bus/usb/devices/usb*/ -name dev); do
        (
            syspath="${sysdevpath%/dev}"
            devname="$(udevadm info -q name -p $syspath)"
            [[ "$devname" == "bus/"* ]] && exit
            eval "$(udevadm info -q property --export -p $syspath)"
            [[ -z "$ID_SERIAL" ]] && exit
            echo "/dev/$devname - $ID_SERIAL"
        )
    done
}

## `wrap_text` wraps text to a specified width and indentation
## Usage: `wrap_text "<text>" [width] [indent]`
function wrap_text() {
    local text=$1
    local width=${2:-80}
    local indent=${3:-0}
    
    if command -v fold &> /dev/null; then
        echo "$text" | fold -s -w "$width" | awk -v indent="$indent" 'NR>1 {printf "%*s", indent, ""} {print}'
    else
        echo "$text"
    fi
}

## `lsinotify` lists inotify watches for each process and displays them in a formatted table
## Usage: `lsinotify`
lsinotify() {
    local SUDO=""
    if [ "$EUID" -ne 0 ]; then
        SUDO="sudo"
        # Prime sudo up-front so the password prompt doesn't appear mid-output
        sudo -v || return 1
    fi

    printf "%-7s %-25s %s\n" "PID" "COMMAND" "TOTAL WATCHES"
    printf "%-7s %-25s -------------\n" "------" "-------------------------"

    local max_watches=""
    [ -r /proc/sys/fs/inotify/max_user_watches ] && \
        max_watches=$(cat /proc/sys/fs/inotify/max_user_watches)

    $SUDO grep -c "^inotify" /proc/*/fdinfo/* 2>/dev/null \
        | awk -F: '$2 > 0' \
        | while IFS=: read -r fd_path watches; do
            local pid=${fd_path#/proc/}
            pid=${pid%%/*}
            local cmd=$(ps -p "$pid" -o comm= 2>/dev/null)
            [ -z "$cmd" ] && continue
            echo "$pid|$cmd|$watches"
        done \
        | awk -F'|' -v max="$max_watches" '
            { watches[$1] += $3; cmd[$1] = $2 }
            END {
                n = 0
                for (p in watches) {
                    n++
                    rows[n] = watches[p] "|" p "|" cmd[p]
                    total += watches[p]
                }
                # sort rows desc by watches
                for (i = 1; i <= n; i++)
                    for (j = i + 1; j <= n; j++) {
                        split(rows[i], a, "|"); split(rows[j], b, "|")
                        if (a[1] + 0 < b[1] + 0) { tmp = rows[i]; rows[i] = rows[j]; rows[j] = tmp }
                    }
                for (i = 1; i <= n; i++) {
                    split(rows[i], a, "|")
                    printf "%-7s %-25s %'"'"'d\n", a[2], a[3], a[1]
                }
                printf "%-7s %-25s -------------\n", "------", "-------------------------"
                if (max != "")
                    printf "%-7s %-25s %'"'"'d / %'"'"'d\n", "TOTAL", n " processes", total, max
                else
                    printf "%-7s %-25s %'"'"'d\n", "TOTAL", n " processes", total
            }
        '
}

## `count` counts files and directories for each path given. For a directory it prints the totals; for a file it prints its line count. Defaults to the current directory.
## Usage: `count` or `count <directory>` or `count <file>` or `count *.js`
function count() {
    # Default to the current directory when no path is given.
    (($# == 0)) && set -- .

    local path
    for path in "$@"; do
        if [[ -d "$path" ]]; then
            local total_files=$(find "$path" -type f | wc -l)
            local total_dirs=$(find "$path" -mindepth 1 -type d | wc -l)
            echo "$path:"
            echo "  Total files: $total_files"
            echo "  Total directories: $total_dirs"
            echo "  Total: $((total_files + total_dirs))"
        elif [[ -f "$path" ]]; then
            echo "Lines in $path: $(wc -l < "$path")"
        else
            echoerr "Error: $path is not a valid file or directory."
            return 1
        fi
    done
}

## h2: WSL-Specific Functions

## `pww` similar to `pw` but from wsl
## Usage: `pww`
function pww() {
    local home_path="$(_wslHomePath)"

    cd "${home_path}/code/work" || return 1
}

## `ppw` similar to `pp` but from wsl
## Usage: `ppw`
function ppw() {
    local home_path="$(_wslHomePath)"

    cd "${home_path}/code/personal" || return 1
}

## h2: File and Directory Compression Functions

## ::: danger Requirements
## This function requires `shred` - `sudo apt install coreutils`.
## :::
## `sd` securely deletes one or more files or directories by overwriting them before deletion
## Usage: `sd <file or directory> [file2] [file3] ... [-f] [-n <passes>]`
## Options:
##   `-f`, `--force`           Force deletion without confirmation prompt<br>
##   `-n`, `--passes <num>`    Number of overwrite passes (default: 5)
function sd() {
    local targets=()
    local force=false
    local passes=5

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--force)
                force=true
                shift
                ;;
            -n|--passes)
                if [[ -z $2 || ! $2 =~ ^[0-9]+$ ]]; then
                    echoerr "Error: -n requires a positive integer"
                    return 1
                fi
                passes=$2
                shift 2
                ;;
            *)
                targets+=("$1")
                shift
                ;;
        esac
    done

    # Check if any targets are provided
    if [[ ${#targets[@]} -eq 0 ]]; then
        echoerr "Error: No target specified."
        echoerr "Usage: sd <file or directory> [file2] [file3] ... [-f] [-n <passes>]"
        return 1
    fi

    # Check if shred is installed
    if ! command -v shred &> /dev/null; then
        echoerr "Error: shred not found. Please install it: sudo apt install coreutils"
        return 1
    fi

    # Validate all targets exist and aren't symlinks
    local invalid_targets=()
    local symlink_targets=()
    
    for target in "${targets[@]}"; do
        if [[ ! -e "$target" ]]; then
            invalid_targets+=("$target")
        elif [[ -L "$target" ]]; then
            symlink_targets+=("$target")
        fi
    done
    
    # Report errors for invalid targets
    if [[ ${#invalid_targets[@]} -gt 0 ]]; then
        echoerr "Error: The following targets were not found:"
        for target in "${invalid_targets[@]}"; do
            echoerr "  - $target"
        done
        return 1
    fi
    
    # Report errors for symlinks
    if [[ ${#symlink_targets[@]} -gt 0 ]]; then
        echoerr "Error: The following targets are symbolic links. Remove them with 'rm' instead:"
        for target in "${symlink_targets[@]}"; do
            echoerr "  - $target"
            echoerr "    Hint: Use 'rm $target' to remove the link, or 'sd \$(readlink -f $target)' to shred the target."
        done
        return 1
    fi

    # Confirmation prompt (unless -f flag is used)
    if [[ "$force" == false ]]; then
        echo "WARNING: You are about to securely delete ${#targets[@]} item(s):"
        for target in "${targets[@]}"; do
            local item_type="file"
            [[ -d "$target" ]] && item_type="directory"
            echo "  - $target ($item_type)"
        done
        echo "This operation is IRREVERSIBLE and will overwrite the data $passes time(s)."
        read -p "Continue? [Y/n]: " confirmation
        
        # Default to Y if empty (just Enter pressed)
        confirmation=${confirmation:-Y}
        
        # Convert to lowercase for comparison
        confirmation=$(echo "$confirmation" | tr '[:upper:]' '[:lower:]')
        
        if [[ "$confirmation" != "y" && "$confirmation" != "yes" ]]; then
            echo "Operation cancelled."
            return 0
        fi
    fi

    # Process each target
    local failed_targets=()
    local success_count=0
    
    for target in "${targets[@]}"; do
        local sudo_cmd
        sudo_cmd=$(sudo_if_needed "$target")
        
        # If it's a directory, use find to securely delete all files within it
        if [[ -d "$target" ]]; then
            echo "Securely deleting files in directory: $target"
            
            # Count files for progress indication
            local file_count
            file_count=$(find "$target" -type f | wc -l)
            
            if [[ $file_count -eq 0 ]]; then
                echo "No files to shred in directory."
            else
                echo "Shredding $file_count file(s) with $passes overwrite pass(es)..."
                
                # Shred all files: -n (passes), -v (verbose), -z (zero), -u (remove)
                $sudo_cmd find "$target" -type f -exec shred -n "$passes" -vzu {} \;
                local exit_code=$?
                
                if [[ $exit_code -ne 0 ]]; then
                    echoerr "Error: Failed to shred some files in '$target' (exit code $exit_code)"
                    failed_targets+=("$target")
                    continue
                fi
            fi
            
            # Remove the empty directory structure
            echo "Removing directory structure..."
            $sudo_cmd rm -rf "$target"
            
            if [[ $? -eq 0 ]]; then
                echo "Successfully deleted: $target"
                ((success_count++))
            else
                echoerr "Error: Failed to remove directory '$target'"
                failed_targets+=("$target")
            fi
        else
            # If it's a file, securely delete it directly
            echo "Securely deleting file: $target"
            $sudo_cmd shred -n "$passes" -vzu "$target"
            local exit_code=$?
            
            if [[ $exit_code -eq 0 ]]; then
                echo "Successfully deleted: $target"
                ((success_count++))
            else
                echoerr "Error: Failed to shred file '$target' (exit code $exit_code)"
                failed_targets+=("$target")
            fi
        fi
    done
    
    # Summary
    echo ""
    echo "Summary: Successfully deleted $success_count of ${#targets[@]} item(s)"
    
    if [[ ${#failed_targets[@]} -gt 0 ]]; then
        echoerr "Failed to delete ${#failed_targets[@]} item(s):"
        for target in "${failed_targets[@]}"; do
            echoerr "  - $target"
        done
        return 1
    fi
    
    return 0
}

## ::: danger Requirements
## This function requires `7zzs`, see https://www.7-zip.org/download.html
## :::
## `7zc` creates a 7Zip archive using the LZMA2 algorithm
## Usage: `7zc <file or directory> [file2] [dir2] ... [-n <name>] [-p] [-s <size>] [-f]`
## Options:
##   `-n`, `--name <name>`    Archive name (without extension). Required when archiving multiple items; defaults to the single item's basename otherwise.<br>
##   `-f`, `--force`          Skip the confirmation prompt.<br>
##   `-p`              Prompt for password to encrypt the archive<br>
##   `-s <size>`       Split archive into parts of specified size. Supports `b` (bytes)/`k` (kilobytes)/`m` (megabytes)/`g` (gigabytes) units (e.g., `-s 500m`, `-s 1g`, `-s 2048k`). Defaults to MB if no unit specified.
function 7zc() {
    # Check if 7zzs is installed
    if ! command -v 7zzs &> /dev/null; then
        echoerr "Error: 7zzs not found. Please install 7zzs from https://www.7-zip.org/download.html"
        return 1
    fi

    local targets=()
    local archive_name=""
    local use_password=false
    local password=""
    local split_size=""
    local force=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -n|--name)
                if [[ -z $2 ]]; then
                    echoerr "Error: -n/--name requires an argument"
                    return 1
                fi
                archive_name=$2
                shift 2
                ;;
            -f|--force)
                force=true
                shift
                ;;
            -p)
                use_password=true
                shift
                ;;
            -s)
                if [[ -z $2 ]]; then
                    echoerr "Error: -s requires a size argument"
                    return 1
                fi

                # Parse size with optional unit (b, k, m, g)
                if [[ $2 =~ ^([0-9]+)([bkmg])?$ ]]; then
                    local size_num="${BASH_REMATCH[1]}"
                    local size_unit="${BASH_REMATCH[2]}"
                    [[ -z "$size_unit" ]] && size_unit="m"
                    split_size="${size_num}${size_unit}"
                else
                    echoerr "Error: -s requires a valid size (e.g., 500, 500m, 1g, 2048k)"
                    return 1
                fi
                shift 2
                ;;
            *)
                targets+=("$1")
                shift
                ;;
        esac
    done

    # Check if any targets are provided
    if [[ ${#targets[@]} -eq 0 ]]; then
        echoerr "Error: No target specified."
        echoerr "Usage: 7zc <file or directory> [file2] [dir2] ... [-n <name>] [-p] [-s <size>]"
        return 1
    fi

    # Validate all targets exist
    local invalid_targets=()
    for target in "${targets[@]}"; do
        [[ ! -e "$target" ]] && invalid_targets+=("$target")
    done

    if [[ ${#invalid_targets[@]} -gt 0 ]]; then
        echoerr "Error: The following targets were not found:"
        for target in "${invalid_targets[@]}"; do
            echoerr "  - $target"
        done
        return 1
    fi

    # Determine archive name
    if [[ -z "$archive_name" ]]; then
        if [[ ${#targets[@]} -eq 1 ]]; then
            archive_name=$(basename "${targets[0]%/}")
        else
            echoerr "Error: -n/--name is required when archiving multiple items."
            echoerr "Example: 7zc ${targets[0]} ${targets[1]} -n my-archive"
            return 1
        fi
    fi

    # Strip trailing .7z if user passed it
    archive_name="${archive_name%.7z}"
    local output="${archive_name}.7z"

    # Refuse to overwrite an existing archive
    if [[ -e "$output" ]]; then
        echoerr "Error: $output already exists. Choose a different name with -n."
        return 1
    fi

    # List what's being archived
    if [[ -n "$split_size" ]]; then
        echo "Compressing ${#targets[@]} item(s) into $output (split: ${split_size}):"
    else
        echo "Compressing ${#targets[@]} item(s) into $output:"
    fi
    for target in "${targets[@]}"; do
        local item_type="file"
        [[ -d "$target" ]] && item_type="directory"
        echo "  - $target ($item_type)"
    done

    # Confirmation prompt (unless -f flag is used)
    if [[ "$force" == false ]]; then
        read -p "Continue? [Y/n]: " confirmation
        confirmation=${confirmation:-Y}
        confirmation=$(echo "$confirmation" | tr '[:upper:]' '[:lower:]')
        if [[ "$confirmation" != "y" && "$confirmation" != "yes" ]]; then
            echo "Operation cancelled."
            return 0
        fi
    fi

    # Handle password prompt if -p flag was set
    if [[ "$use_password" == true ]]; then
        read -s -p "Enter password: " password
        echo
        if [[ -z "$password" ]]; then
            echoerr "Error: Password cannot be empty"
            return 1
        fi
        read -s -p "Confirm password: " password_confirm
        echo
        if [[ "$password" != "$password_confirm" ]]; then
            echoerr "Error: Passwords do not match"
            return 1
        fi
    fi

    # Build 7z command with optional split and password
    # Using maximum compression: LZMA2, ultra (-mx9), 64 word size, 32MB dictionary, solid archive
    local cmd="7zzs a -t7z -m0=lzma2 -mx9 -mfb=64 -md=32m -ms=on"
    [[ -n "$split_size" ]] && cmd="$cmd -v$split_size"
    [[ "$use_password" == true ]] && cmd="$cmd -mhe=on -p\"$password\""
    cmd="$cmd \"$output\""
    for target in "${targets[@]}"; do
        cmd="$cmd \"$target\""
    done

    eval $cmd
    return $?
}

## ::: danger Requirements
## This function requires `7zzs`, see https://www.7-zip.org/download.html
## :::
## `7zx` extracts a 7Zip archive to a directory with the same name as the archive.
## Supported formats: `zip`, `rar`, `7z`, `tar`, `tar.gz`, `tgz`, `tar.bz2`, `tbz2`, `tar.xz`, `txz`, `gz`, `bz2`, `xz`
##
## ::: warning Multi-part Archives
## For multi-part archives, **always extract the first part** and 7-Zip will automatically use all parts:
## - 7-Zip format: `archive.7z.001` (extract this, not `.002`, `.003`, etc.)
## - RAR format: `archive.rar` (extract this, not `.r00`, `.r01`, etc.) or `archive.part1.rar` or `archive.part01.rar`
## :::
## Usage: `7zx <filename>.7z` or `7zx <filename>.7z.001` (for multi-part archives)
function 7zx() {
    # Check if 7zzs is installed
    if ! command -v 7zzs &> /dev/null; then
        echoerr "Error: 7zzs not found. Please install 7zzs from https://www.7-zip.org/download.html"
        return 1
    fi

    # Check if argument is provided
    if [[ -z $1 ]]; then
        echoerr "Error: No archive file specified."
        echoerr "Usage: 7zx <archive_file>"
        return 1
    fi

    local file_name="$1"

    # Check if file exists
    if [[ ! -f "$file_name" ]]; then
        echoerr "Error: File '$file_name' not found"
        return 1
    fi

    local extension="${file_name##*.}"
    local dir_name
    local base_name=$(basename "$file_name")

    # Check if user is trying to extract a non-first part of a multi-part RAR archive
    if [[ "$base_name" =~ \.(r[0-9]{2})$ ]]; then
        local first_part="${file_name%.r[0-9][0-9]}.rar"
        echoerr "Error: You're trying to extract part ${BASH_REMATCH[1]} of a multi-part RAR archive."
        echoerr "Please extract the first part instead: $first_part"
        echoerr "7-Zip will automatically use all parts."
        return 1
    fi
    
    if [[ "$base_name" =~ \.part([0-9]+)\.rar$ ]] && [[ "${BASH_REMATCH[1]}" != "1" ]] && [[ "${BASH_REMATCH[1]}" != "01" ]]; then
        echoerr "Error: You're trying to extract part ${BASH_REMATCH[1]} of a multi-part RAR archive."
        echoerr "Please extract the first part instead (part1.rar or part01.rar)."
        echoerr "7-Zip will automatically use all parts."
        return 1
    fi

    # Determine the directory name based on the file extension
    case "$extension" in
        zip)
            dir_name="${base_name%.zip}"
            ;;
        rar)
            # Handle multi-part rar formats:
            # - archive.part1.rar, archive.part2.rar, etc. (text numbers)
            # - archive.part01.rar, archive.part02.rar, etc. (leading zeros)
            # - archive.rar is the first part (may have .r00, .r01 as additional parts)
            if [[ "$base_name" =~ \.part0*1\.rar$ ]]; then
                # First part with .part1.rar or .part01.rar format
                dir_name="${base_name%.part*.rar}"
            elif [[ "$base_name" =~ \.part[0-9]+\.rar$ ]]; then
                # Should not reach here due to earlier check, but handle anyway
                dir_name="${base_name%.part*.rar}"
            else
                # Single file or first part of .rar/.r00/.r01 format
                dir_name="${base_name%.rar}"
            fi
            ;;
        7z)
            # Handle multi-part 7z: file.part1.7z, file.part2.7z, etc.
            if [[ "$base_name" =~ \.part[0-9]+\.7z$ ]]; then
                dir_name="${base_name%.part*.7z}"
            else
                dir_name="${base_name%.7z}"
            fi
            ;;
        tar)
            dir_name="${base_name%.tar}"
            ;;
        gz)
            if [[ "$base_name" =~ \.tar\.gz$ ]] || [[ "$base_name" =~ \.tgz$ ]]; then
                dir_name="${base_name%.tar.gz}"
                dir_name="${dir_name%.tgz}"
            else
                dir_name="${base_name%.gz}"
            fi
            ;;
        bz2)
            if [[ "$base_name" =~ \.tar\.bz2$ ]] || [[ "$base_name" =~ \.tbz2$ ]]; then
                dir_name="${base_name%.tar.bz2}"
                dir_name="${dir_name%.tbz2}"
            else
                dir_name="${base_name%.bz2}"
            fi
            ;;
        xz)
            if [[ "$base_name" =~ \.tar\.xz$ ]] || [[ "$base_name" =~ \.txz$ ]]; then
                dir_name="${base_name%.tar.xz}"
                dir_name="${dir_name%.txz}"
            else
                dir_name="${base_name%.xz}"
            fi
            ;;
        tgz)
            dir_name="${base_name%.tgz}"
            ;;
        tbz2)
            dir_name="${base_name%.tbz2}"
            ;;
        txz)
            dir_name="${base_name%.txz}"
            ;;
        *)
            echoerr "Error: Unsupported file extension: $extension"
            echoerr "Supported formats: zip, rar, 7z, tar, tar.gz, tgz, tar.bz2, tbz2, tar.xz, txz, gz, bz2, xz"
            return 1
            ;;
    esac

    # Check if directory already exists
    if [[ -d "$dir_name" ]]; then
        echoerr "Error: Directory '$dir_name' already exists"
        return 1
    fi

    mkdir -p "$dir_name"
    
    echo "Extracting '$file_name' to '$dir_name/'..."
    
    # Try to list archive without password to check if it's encrypted
    # Suppress only stderr to hide "Wrong password" errors during detection
    7zzs l "$file_name" -p- >/dev/null 2>&1
    local exit_code=$?
    
    # If listing failed due to password (exit code 2), prompt for password
    if [[ $exit_code -eq 2 ]]; then
        echo "Archive is password protected."
        local password
        local max_attempts=3
        local attempt=1
        
        while [[ $attempt -le $max_attempts ]]; do
            read -s -p "Enter password (attempt $attempt/$max_attempts): " password
            echo
            
            if [[ -z "$password" ]]; then
                echoerr "Error: Password cannot be empty"
                ((attempt++))
                continue
            fi
            
            # Try extraction with password (show progress)
            7zzs x "$file_name" -o"$dir_name" -p"$password"
            exit_code=$?
            
            if [[ $exit_code -eq 0 ]]; then
                echo "Extraction complete!"
                return 0
            elif [[ $exit_code -eq 2 ]]; then
                echoerr "Error: Incorrect password"
                ((attempt++))
            else
                echoerr "Error: Extraction failed with exit code $exit_code"
                rmdir "$dir_name" 2>/dev/null
                return $exit_code
            fi
        done
        
        echoerr "Error: Maximum password attempts exceeded"
        rmdir "$dir_name" 2>/dev/null
        return 1
    elif [[ $exit_code -ne 0 ]]; then
        echoerr "Error: Cannot read archive (exit code $exit_code)"
        rmdir "$dir_name" 2>/dev/null
        return $exit_code
    fi
    
    # Extract without password (show progress)
    7zzs x "$file_name" -o"$dir_name"
    exit_code=$?
    
    if [[ $exit_code -ne 0 ]]; then
        echoerr "Error: Extraction failed with exit code $exit_code"
        rmdir "$dir_name" 2>/dev/null
        return $exit_code
    fi
    
    echo "Extraction complete!"
    return 0
}

## ::: danger Requirements
## This function requires `zstd`. Install it from `sudo apt install zstd` or download it from [GitHub Release](https://github.com/facebook/zstd/releases).
## :::
## `zc` compresses one or more files/directories into a single zstd-compressed tar archive
## Usage: `zc <file or directory> [file2] [dir2] ... [-n <name>] [-f]`
## Options:
##   `-n`, `--name <name>`    Archive name (without extension). Required when archiving multiple items; defaults to the single item's basename otherwise.<br>
##   `-f`, `--force`          Skip the confirmation prompt.
function zc() {
    local targets=()
    local archive_name=""
    local force=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -n|--name)
                if [[ -z $2 ]]; then
                    echoerr "Error: -n/--name requires an argument"
                    return 1
                fi
                archive_name=$2
                shift 2
                ;;
            -f|--force)
                force=true
                shift
                ;;
            *)
                targets+=("$1")
                shift
                ;;
        esac
    done

    # Check if any targets are provided
    if [[ ${#targets[@]} -eq 0 ]]; then
        echoerr "Error: No target specified."
        echoerr "Usage: zc <file or directory> [file2] [dir2] ... [-n <name>]"
        return 1
    fi

    # Check if zstd is installed
    if ! command -v zstd &> /dev/null; then
        echoerr "Error: zstd not found."
        return 1
    fi

    # Validate all targets exist
    local invalid_targets=()
    for target in "${targets[@]}"; do
        [[ ! -e "$target" ]] && invalid_targets+=("$target")
    done

    if [[ ${#invalid_targets[@]} -gt 0 ]]; then
        echoerr "Error: The following targets were not found:"
        for target in "${invalid_targets[@]}"; do
            echoerr "  - $target"
        done
        return 1
    fi

    # Determine archive name
    if [[ -z "$archive_name" ]]; then
        if [[ ${#targets[@]} -eq 1 ]]; then
            archive_name=$(basename "${targets[0]}")
        else
            echoerr "Error: -n/--name is required when archiving multiple items."
            echoerr "Example: zc ${targets[0]} ${targets[1]} -n my-archive"
            return 1
        fi
    fi

    local output="${archive_name}.tar.zst"

    # Refuse to overwrite an existing archive
    if [[ -e "$output" ]]; then
        echoerr "Error: $output already exists. Choose a different name with -n."
        return 1
    fi

    # List what's being archived
    echo "Compressing ${#targets[@]} item(s) into $output:"
    for target in "${targets[@]}"; do
        local item_type="file"
        [[ -d "$target" ]] && item_type="directory"
        echo "  - $target ($item_type)"
    done

    # Confirmation prompt (unless -f flag is used)
    if [[ "$force" == false ]]; then
        read -p "Continue? [Y/n]: " confirmation
        confirmation=${confirmation:-Y}
        confirmation=$(echo "$confirmation" | tr '[:upper:]' '[:lower:]')
        if [[ "$confirmation" != "y" && "$confirmation" != "yes" ]]; then
            echo "Operation cancelled."
            return 0
        fi
    fi

    if command -v pv &> /dev/null; then
        local total_size=0
        for target in "${targets[@]}"; do
            total_size=$((total_size + $(du -sb "$target" | awk '{print $1}')))
        done
        tar -cf - "${targets[@]}" | pv -s "$total_size" | zstd -T0 -19 --no-progress -q -o "$output"
    else
        tar --use-compress-program="zstd -T0 -19" -cf "$output" "${targets[@]}"
    fi
}

## ::: danger Requirements
## This function requires `zstd`. Install it from `sudo apt install zstd` or download it from [GitHub Release](https://github.com/facebook/zstd/releases).
## :::
## `zx` extracts a zstd compressed tar file
## Usage: `zx <file.tar.zst>`
function zx() {
    local file=$1
    local file_name=$(basename "$file" .tar.zst)

    # Check if the first argument is not empty
    if [[ -z $file ]]; then
        echoerr "Error: No arguments provided."
        return
    fi

    # Check if zstd is installed
    if ! command -v zstd &> /dev/null; then
        echoerr "Error: zstd not found."
        return
    fi

    # Check if the file exists
    if [[ ! -e $file ]]; then
        echoerr "Error: $file not found."
        return
    fi

    local sudo_cmd
    sudo_cmd=$(sudo_if_needed "$file")

    # Extract the file
    $sudo_cmd tar --use-compress-program="zstd -d" -xf "$file"
}

## `tgc` compresses one or more files/directories into a single gzip-compressed tar archive
## Usage: `tgc <file or directory> [file2] [dir2] ... [-n <name>] [-f]`
## Options:
##   `-n`, `--name <name>`    Archive name (without extension). Required when archiving multiple items; defaults to the single item's basename otherwise.<br>
##   `-f`, `--force`          Skip the confirmation prompt.
function tgc() {
    local targets=()
    local archive_name=""
    local force=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -n|--name)
                if [[ -z $2 ]]; then
                    echoerr "Error: -n/--name requires an argument"
                    return 1
                fi
                archive_name=$2
                shift 2
                ;;
            -f|--force)
                force=true
                shift
                ;;
            *)
                targets+=("$1")
                shift
                ;;
        esac
    done

    # Check if any targets are provided
    if [[ ${#targets[@]} -eq 0 ]]; then
        echoerr "Error: No target specified."
        echoerr "Usage: tgc <file or directory> [file2] [dir2] ... [-n <name>]"
        return 1
    fi

    # Validate all targets exist
    local invalid_targets=()
    for target in "${targets[@]}"; do
        [[ ! -e "$target" ]] && invalid_targets+=("$target")
    done

    if [[ ${#invalid_targets[@]} -gt 0 ]]; then
        echoerr "Error: The following targets were not found:"
        for target in "${invalid_targets[@]}"; do
            echoerr "  - $target"
        done
        return 1
    fi

    # Determine archive name
    if [[ -z "$archive_name" ]]; then
        if [[ ${#targets[@]} -eq 1 ]]; then
            archive_name=$(basename "${targets[0]%/}")
        else
            echoerr "Error: -n/--name is required when archiving multiple items."
            echoerr "Example: tgc ${targets[0]} ${targets[1]} -n my-archive"
            return 1
        fi
    fi

    # Strip trailing .tar.gz if user passed it
    archive_name="${archive_name%.tar.gz}"
    local output="${archive_name}.tar.gz"

    # Refuse to overwrite an existing archive
    if [[ -e "$output" ]]; then
        echoerr "Error: $output already exists. Choose a different name with -n."
        return 1
    fi

    # List what's being archived
    echo "Compressing ${#targets[@]} item(s) into $output:"
    for target in "${targets[@]}"; do
        local item_type="file"
        [[ -d "$target" ]] && item_type="directory"
        echo "  - $target ($item_type)"
    done

    # Confirmation prompt (unless -f flag is used)
    if [[ "$force" == false ]]; then
        read -p "Continue? [Y/n]: " confirmation
        confirmation=${confirmation:-Y}
        confirmation=$(echo "$confirmation" | tr '[:upper:]' '[:lower:]')
        if [[ "$confirmation" != "y" && "$confirmation" != "yes" ]]; then
            echo "Operation cancelled."
            return 0
        fi
    fi

    if command -v pv &> /dev/null; then
        local total_size=0
        for target in "${targets[@]}"; do
            total_size=$((total_size + $(du -sb "$target" | awk '{print $1}')))
        done
        tar -cf - "${targets[@]}" | pv -s "$total_size" | gzip > "$output"
    else
        tar -czf "$output" "${targets[@]}"
    fi
}

## `tgx` extracts a gzip compressed tar file
## Usage: `tgx <file.tar.gz>`
function tgx() {
    local file=$1

    # Check if the first argument is not empty
    if [[ -z $file ]]; then
        echoerr "Error: No arguments provided."
        return
    fi

    # Check if the file exists
    if [[ ! -e $file ]]; then
        echoerr "Error: $file not found."
        return
    fi

    local sudo_cmd
    sudo_cmd=$(sudo_if_needed "$file")

    # Extract the file (with progress bar if pv is available)
    if command -v pv &> /dev/null; then
        pv "$file" | $sudo_cmd tar -xzf -
    else
        $sudo_cmd tar -xzf "$file"
    fi
}

## h2: Git Related Functions

## `gclone` clones a git repository and cd's into it
## Usage: `gclone <git_url>`
function gclone() {
    # Check if git is installed
    if ! command -v git &> /dev/null; then
        echoerr "Error: git not found. Please install git from https://git-scm.com/downloads"
        return
    fi

    # Check if the first argument is not empty
    if [[ -z $1 ]]; then
        echoerr "Error: No arguments provided."
        return
    fi

    # Clone the repository
    git clone "$1" && cd "$(basename "$1" .git)"
}

## `gsubd` removed the current Git submodule and its entry in `.gitmodules`
## Usage: `gsubd <submodule_path>`
function gsubd() {
    # Check if git is installed
    if ! command -v git &> /dev/null; then
        echoerr "Error: git not found. Please install git from https://git-scm.com/downloads"
        return
    fi

    local SUBMODULE_PATH="$1"

    # Check if the first argument is not empty
    if [[ -z $SUBMODULE_PATH ]]; then
        echoerr "Error: No path provided."
        return
    fi

    # Check if the submodule exists
    if [[ ! -e $SUBMODULE_PATH ]]; then
        echoerr "Error: $SUBMODULE_PATH not found."
        return
    fi

    # Remove the submodule entry from .git/config
    git submodule deinit -f "$SUBMODULE_PATH"

    # Remove the submodule from the index and working tree
    git rm -f $SUBMODULE_PATH

    # Clean up the .gitmodules file
    git config -f .gitmodules --remove-section submodule.$SUBMODULE_PATH 2> /dev/null

    # Remove the leftover submodule directory in .git/modules
    rm -rf .git/modules/$SUBMODULE_PATH
}

## `gclean` removes all untracked files, including ignored files and directories
## Usage: `gclean`
function gclean() {
    # Check if git is installed
    if ! command -v git &> /dev/null; then
        echoerr "Error: git not found. Please install git from https://git-scm.com/downloads"
        return
    fi

    # Remove all untracked files, including ignored files and directories
    # Add -n flag to do a dry run
    git clean -Xfd
}

## `gcl` Generates a changelog from the commit history
## Usage: `gcl`
function gcl() {
    # Check if git is installed
    if ! command -v git &> /dev/null; then
        echoerr "Error: git not found. Please install git from https://git-scm.com/downloads"
        return
    fi

    # Check if in master or main branch if so, else warn the user
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD)
    if [[ "$branch" == "main" && "$branch" == "master" ]]; then
        echoerr "Warning: You are in the main or master branch. The changelog will be generated from the current branch."
    fi

    # Get the change log from the main/master branch till HEAD and print it in a bullet list format
    git log --pretty=format:'- %s' "$branch"
}

# =========================================================================================================
# ============================================== Dotfiles =================================================
# =========================================================================================================

## h2: Dotfiles Related Functions

function _dot_help() {
    echo -e "Your friendly dotfiles to make your life easier.\n"
    echo "Usage: dot [command]"
    echo
    echo "Commands:"
    echo "  u, update   Updates the dotfiles to the latest main branch"
    echo "  ls          Lists all the aliases and functions in the dotfiles and the shell"
}

## `dot` prints help for the dotfiles and can be used to run the dotfiles functions
## Usage: `dot` or `dot <command>`
function dot() {
    if [[ -z $1 ]]; then
        _dot_help
        return
    fi

    case $1 in
        "u"|"update")
            dotu
            ;;
        "ls")
            dotls
            ;;
        *)
            _dot_help
            ;;
    esac
}

## `dotu` updates the dotfiles to the latest main branch
## Usage: `dotu`
function dotu() {
    local current_dir repo_dir current_hash remote_hash
    current_dir=$(pwd)
    repo_dir=$(_whereami)
    
    # Check if repo directory exists
    if [[ ! -d "$repo_dir" ]]; then
        echoerr "Repository directory not found: $repo_dir"
        return 1
    fi
    
    cd "$repo_dir" || {
        echoerr "Failed to change to repository directory"
        return 1
    }

    # Check if we're in a git repository
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echoerr "Not a git repository: $repo_dir"
        cd "$current_dir"
        return 1
    fi

    # Check for uncommitted changes
    if ! git diff-index --quiet HEAD -- 2>/dev/null; then
        echoerr "You have uncommitted changes. Please commit or stash them first."
        git status --short
        cd "$current_dir"
        return 1
    fi

    # Fetch updates with loading animation
    (git fetch origin main 2>/dev/null) &
    local fetch_pid=$!
    _loading "$fetch_pid" "Checking for updates"
    
    # Wait for fetch to complete
    if ! wait "$fetch_pid"; then
        echoerr "Failed to fetch updates. Check your network connection."
        cd "$current_dir"
        return 1
    fi

    # Get current hash
    current_hash=$(git rev-parse HEAD)
    # Get remote hash
    remote_hash=$(git rev-parse origin/main 2>/dev/null)

    # Check if remote hash retrieval failed
    if [[ -z "$remote_hash" ]]; then
        echoerr "Could not fetch remote hash"
        cd "$current_dir"
        return 1
    fi

    # Check if already up to date
    if [[ "$remote_hash" == "$current_hash" ]]; then
        _greenText "Already up to date."
    else
        # Pull the latest changes with loading animation
        (git pull --quiet origin main) &
        local pull_pid=$!
        _loading "$pull_pid" "Downloading updates"
        
        # Wait for pull to complete
        if ! wait "$pull_pid"; then
            echoerr "Failed to pull updates. You may have merge conflicts."
            cd "$current_dir"
            return 1
        fi

        _greenText "✓ Updated successfully!"
        echo "View changes: https://github.com/akshaybabloo/dotfiles/compare/$current_hash...$remote_hash"
    fi

    # Run updater script if it exists (always run, even if already up to date)
    if [[ -f "$repo_dir/updater.sh" ]]; then
        echo "Running updater script..."
        if bash "$repo_dir/updater.sh"; then
            _greenText "✓ Updater completed"
        else
            echoerr "Updater script failed"
            cd "$current_dir"
            return 1
        fi
    fi

    cd "$current_dir"
    
    # Reload shell configuration if reload function exists
    if command -v reload &>/dev/null; then
        echo "Reloading shell configuration..."
        reload
    else
        _blueText "Please restart your shell or run: source ~/.bashrc"
    fi
    
    return 0
}

## `dotub` updates binary files only to its latest version from GitHub releases.
## Usage: `dotub` or `dotub --dry-run` to see what would be updated without actually updating
function dotub() {
    local dry_run=false
    case "${1:-}" in
        "")
            ;;
        "--dry-run")
            dry_run=true
            ;;
        *)
            echoerr "Unknown argument: $1"
            echo "Usage: dotub [--dry-run]"
            return 2
            ;;
    esac

    if [[ $# -gt 1 ]]; then
        echoerr "Too many arguments"
        echo "Usage: dotub [--dry-run]"
        return 2
    fi

    if [[ "$dry_run" == true ]]; then
        _blueText "Checking for binary updates (dry run)..."
    else
        _blueText "Checking for binary updates..."
    fi

    local script_dir=$(_whereami)
    local config_dir="$script_dir/binary_configs"

    if [[ ! -d $config_dir ]]; then
        die "Config directory not found: $config_dir"
    fi

    # Check if binstall is installed
    if ! command -v binstall &> /dev/null; then
        die "binstall not found"
    fi

    if [[ "$dry_run" == true ]]; then
        binstall download "$config_dir" --dry-run
    else
        binstall download "$config_dir"
    fi
}

## `dotls` lists all the aliases and functions in the dotfiles with their descriptions
## Usage: `dotls`
function dotls() {
    local script_dir
    script_dir=$(_whereami)

    # Color codes
    local BOLD=$'\033[1m'
    local DIM=$'\033[2m'
    local CYAN=$'\033[0;36m'
    local MAGENTA=$'\033[0;35m'
    local YELLOW=$'\033[0;33m'
    local BLUE=$'\033[1;94m'
    local NC=$'\033[0m'

    # Terminal width
    local term_width=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
    local name_width=22
    local desc_width=$((term_width - name_width - 4))

    # Inner renderer: walks a file, emits sections from `## h2:` markers
    # and entries matched by the given grep pattern + name extractor.
    #   $1: file path
    #   $2: 'alias' or 'function' (governs entry detection + fallback display)
    _dotls_render() {
        local file=$1 kind=$2
        local description=""
        local h2_re='^##[[:space:]]+h2:[[:space:]]*(.+)$'
        local fn_re='^function[[:space:]]+([^_][^(]*)\(\)'

        while IFS= read -r line; do
            # Section header: `## h2: Some Section`
            if [[ $line =~ $h2_re ]]; then
                printf '\n  %s%s▸ %s%s\n' "$BOLD" "$YELLOW" "${BASH_REMATCH[1]}" "$NC"
                printf '  %s%s%s\n' "$DIM" "$(printf '%.0s─' $(seq 1 $((term_width - 4))))" "$NC"
                description=""
                continue
            fi

            # Description comment line (`##` but not h2:/Usage:/Options:/Examples:/:::)
            if [[ $line == \#\#* ]]; then
                if [[ ! $line =~ ^##\ (Usage:|Options:|Examples:) ]]; then
                    local desc
                    desc=$(echo "$line" | sed -E 's/^##[[:space:]]*//')
                    if [[ ! $desc =~ ^::: ]]; then
                        if [[ -n $description ]]; then
                            description="$description $desc"
                        else
                            description="$desc"
                        fi
                    fi
                fi
                continue
            fi

            # Entry line
            local name=""
            local fallback=""
            if [[ $kind == "alias" && $line == alias* ]]; then
                name=$(echo "$line" | sed -E 's/alias ([^=]+)=.*/\1/')
                local alias_def
                alias_def=$(echo "$line" | sed -E 's/alias [^=]+=(.*)$/\1/')
                if [[ $alias_def == *"#"* ]]; then
                    fallback=$(echo "$alias_def" | sed -E 's/([^#]+)#.*/\1/' | xargs)
                else
                    fallback="$alias_def"
                fi
            elif [[ $kind == "function" && $line =~ $fn_re ]]; then
                name="${BASH_REMATCH[1]}"
            fi

            if [[ -n $name ]]; then
                printf '  %s%-*s%s' "$CYAN" "$name_width" "$name" "$NC"
                local text="${description:-$fallback}"
                if [[ -n $text ]]; then
                    # Highlight backticks, then dim the rest
                    local highlighted
                    highlighted=$(echo "$text" | sed -E "s/\`([^\`]+)\`/${MAGENTA}\1${DIM}/g")
                    if command -v fmt &> /dev/null; then
                        printf '%s%s%s\n' "$DIM" "$highlighted" "$NC" \
                            | fmt -w "$desc_width" \
                            | awk -v w="$name_width" 'NR==1 {print} NR>1 {printf "%*s%s\n", w+2, "", $0}'
                    else
                        printf '%s%s%s\n' "$DIM" "$highlighted" "$NC"
                    fi
                else
                    echo ""
                fi
                description=""
                continue
            fi

            # Any other non-blank, non-`##` content resets the description buffer
            if [[ -n $line && ! $line =~ ^[[:space:]]*$ ]]; then
                description=""
            fi
        done < "$file"
    }

    printf '\n%s━━━ Aliases ━━━%s\n' "$BLUE" "$NC"
    _dotls_render "$script_dir/.aliases" alias

    printf '\n\n%s━━━ Functions ━━━%s\n' "$BLUE" "$NC"
    _dotls_render "$script_dir/.functions" function

    echo ""
    unset -f _dotls_render
}

